   "source": [
    "# 열번찍어 안 넘어가는 나무 없다 \n",
    "treehit = 0 \n",
    "while treehit < 10: \n",
    "    treehit = treehit + 1 # treehit += 1\n",
    "    print(f\"나무를 {treehit}번 찍었습니다.\")\n",
    "    if treehit == 10: \n",
    "        print(\"나무가 넘어갑니다\")"
   ]
